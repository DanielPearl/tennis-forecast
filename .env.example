# Tennis Forecast (Baseline Break) — environment template.
# Copy to `.env` for local dev. Never commit `.env`.

# --- REQUIRED: Kalshi API credentials ---
# The live monitor reads tennis markets (KXATPMATCH + KXWTAMATCH) via
# the kalshi_sdk; without these, the bot has no markets to forecast.
# On the droplet these come from /root/gas-prices/.env (the existing
# Kalshi creds shared across all bots in the suite).
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# --- Optional pre-match odds source ---
# https://the-odds-api.com — only used by the historical odds-pull
# script. The live monitor uses Kalshi prices directly.
THE_ODDS_API_KEY=

# Dashboard binding (when running the standalone tennis dashboard).
HOST=0.0.0.0
PORT=8090
