# Tennis Forecast (Baseline Break) — environment template.
# Copy to `.env` for local dev. Never commit `.env`.

# --- Optional market/odds data (graceful no-op when missing) ---
# https://the-odds-api.com — free tier ~500 calls/month
THE_ODDS_API_KEY=

# Kalshi (only if you want to reuse the existing kalshi_sdk; the
# tennis bot is market-agnostic and works fine without it)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Optional live tennis data provider — leave blank to use the seeded
# Sackmann historical CSVs + the synthetic-live demo path.
SOFASCORE_BASE_URL=https://api.sofascore.com/api/v1

# Dashboard binding
HOST=0.0.0.0
PORT=8090
